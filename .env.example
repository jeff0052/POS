# === MySQL ===
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_password
MYSQL_DATABASE=pos_v2_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=CHANGE_ME_strong_password

# === Authentication (REQUIRED) ===
JWT_SECRET=CHANGE_ME_must_be_at_least_32_characters_long
AUTH_BOOTSTRAP_SECRET=CHANGE_ME_one_time_bootstrap_secret

# === Payment Service (REQUIRED for production) ===
POS_CALLBACK_SECRET=CHANGE_ME_payment_callback_hmac_secret
PAYMENT_SERVICE_API_KEY=CHANGE_ME_payment_service_api_key

# === VibeCash QR Payment (optional) ===
VIBECASH_ENABLED=false
VIBECASH_API_URL=https://api.vibecash.dev
VIBECASH_SECRET=
VIBECASH_WEBHOOK_SECRET=
VIBECASH_CURRENCY=SGD

# === DCS Card Payment (optional) ===
DCS_ENABLED=false

# === AWS S3 Image Storage (REQUIRED for image upload) ===
AWS_ACCESS_KEY_ID=CHANGE_ME_aws_access_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_aws_secret_key
S3_BUCKET=founderpos-images
S3_REGION=us-east-1

# === Application ===
APP_PORT=80
